[Unit]
Description=Redis persistent key-value database
After=network.target

[Service]
ExecStart={{ redis_bin_path }}/redis-server {{ redis_default_settings.configdir }}/redis.conf
ExecStop={{ redis_bin_path }}/redis-cli -h {{ redis_bind }} -p {{ redis_port }} {% if redis_requirepass %}--auth {{ redis_requirepass }}{% endif %} shutdown
User=redis
Group=redis
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
Type=simple
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target