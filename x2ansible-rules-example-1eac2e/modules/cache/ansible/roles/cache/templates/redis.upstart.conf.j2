description "Start the redis instance on port {{ redis_port }}"
author "Installed by Ansible cache role"

#start on runlevel [2345]
stop on runlevel [06]

script
  if [ ! -d {{ redis_base_piddir }} ]; then
    mkdir -p {{ redis_base_piddir }}
    chown redis:redis {{ redis_base_piddir }}
  fi
end script

# If the job exits, restart it. Give up with more than 10 restarts in 30 seconds.
respawn
respawn limit 10 30

exec su -s /bin/sh -c 'exec "$0" "$@"' redis {{ redis_bin_path }}/redis-server {{ redis_default_settings.configdir }}/redis.conf