# Memcached configuration file
# Generated by Ansible

{% if ansible_os_family == 'Debian' %}
# Run memcached as a daemon
-d

# Log memcached's output to /var/log/memcached
logfile /var/log/memcached.log

# Start with a cap of 64 megs of memory
-m {{ memcached_memory }}

# Default connection port is 11211
-p {{ memcached_port }}

# Run the daemon as memcache
-u memcache

# Specify which IP address to listen on
-l {{ memcached_listen_address }}

# Limit the number of simultaneous incoming connections
-c {{ memcached_connections }}

{% else %}
# RedHat/CentOS configuration
PORT="{{ memcached_port }}"
USER="memcached"
MAXCONN="{{ memcached_connections }}"
CACHESIZE="{{ memcached_memory }}"
OPTIONS="-l {{ memcached_listen_address }}"
{% endif %}