# Redis configuration file

# General
daemonize yes
pidfile /var/run/redis/redis-{{ redis_port }}.pid
port {{ redis_port }}
tcp-backlog 511
timeout 0
tcp-keepalive 0
loglevel notice
logfile /var/log/redis/redis-{{ redis_port }}.log
databases 16

# Snapshotting
save 900 1
save 300 10
save 60 10000
stop-writes-on-bgsave-error yes
rdbcompression yes
rdbchecksum yes
dbfilename dump-{{ redis_port }}.rdb
dir /var/lib/redis/{{ redis_port }}

# Replication
{% if redis_servers[0].requirepass is defined %}
requirepass {{ redis_servers[0].requirepass }}
{% endif %}

# Security
{% if redis_servers[0].requirepass is defined %}
masterauth {{ redis_servers[0].requirepass }}
{% endif %}

# Limits
maxclients 10000
maxmemory-policy noeviction

# Append only mode
appendonly no
appendfilename "appendonly-{{ redis_port }}.aof"
appendfsync everysec
no-appendfsync-on-rewrite no
auto-aof-rewrite-percentage 100
auto-aof-rewrite-min-size 64mb
aof-load-truncated yes

# LUA scripting
lua-time-limit 5000

# Slow log
slowlog-log-slower-than 10000
slowlog-max-len 128

# Event notification
notify-keyspace-events ""

# Advanced config
hash-max-ziplist-entries 512
hash-max-ziplist-value 64
list-max-ziplist-entries 512
list-max-ziplist-value 64
set-max-intset-entries 512
zset-max-ziplist-entries 128
zset-max-ziplist-value 64
hll-sparse-max-bytes 3000
activerehashing yes
client-output-buffer-limit normal 0 0 0
client-output-buffer-limit slave 256mb 64mb 60
client-output-buffer-limit pubsub 32mb 8mb 60
hz 10
aof-rewrite-incremental-fsync yes