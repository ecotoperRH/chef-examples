# memcached default config file
# 2003 - Jay Bonci <jaybonci@debian.org>
# This configuration file is read by the start-memcached script provided by
# the memcached package.

# Run memcached as a daemon
-d

# Log memcached's output to /var/log/memcached
logfile /var/log/memcached.log

# Memory cap (in MB)
-m {{ memcached_memory }}

# Default connection port is 11211
-p {{ memcached_port }}

# Run the daemon as this user
-u {{ memcached_user }}

# Specify which IP address to listen on. Default is to listen on all IP addresses.
-l {{ memcached_listen_ip }}

# Limit the number of simultaneous incoming connections.
-c {{ memcached_max_connections }}

# Use UDP and TCP
-U {{ memcached_port }}

# Start with a cap of 1024 objects in the cache
-C

# Default size of each slab page
-I 1M